{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "ai-simulation-result.schema.json",
  "title": "AiSimulationResult",
  "type": "object",
  "required": ["summary", "visibleMetricDeltas", "hiddenScoreDeltas", "financeDelta", "groupImpacts", "randomEvents", "nextIssues"],
  "properties": {
    "summary": { "type": "string" },
    "visibleMetricDeltas": {
      "type": "object",
      "required": [
        "support",
        "happiness",
        "academic",
        "fairness",
        "rule",
        "participation",
        "externalReputation",
        "externalAchievements",
        "teacherSatisfaction"
      ],
      "properties": {
        "support": { "type": "number" },
        "happiness": { "type": "number" },
        "academic": { "type": "number" },
        "fairness": { "type": "number" },
        "rule": { "type": "number" },
        "participation": { "type": "number" },
        "externalReputation": { "type": "number" },
        "externalAchievements": { "type": "number" },
        "teacherSatisfaction": { "type": "number" }
      },
      "additionalProperties": false
    },
    "hiddenScoreDeltas": {
      "type": "object",
      "required": ["trust", "polarization", "fatigue", "publicValue"],
      "properties": {
        "trust": { "type": "number" },
        "polarization": { "type": "number" },
        "fatigue": { "type": "number" },
        "publicValue": { "type": "number" }
      },
      "additionalProperties": false
    },
    "financeDelta": {
      "type": "object",
      "required": ["budget", "cash"],
      "properties": {
        "budget": { "type": "number" },
        "cash": { "type": "number" }
      },
      "additionalProperties": false
    },
    "groupImpacts": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["groupId", "summary", "scoreDelta"],
        "properties": {
          "groupId": { "type": "string" },
          "summary": { "type": "string" },
          "scoreDelta": { "type": "number" }
        },
        "additionalProperties": false
      }
    },
    "randomEvents": { "type": "array", "items": { "type": "string" } },
    "nextIssues": { "type": "array", "items": { "type": "string" } }
  },
  "additionalProperties": false
}
