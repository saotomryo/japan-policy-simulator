{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "issue-candidate.schema.json",
  "title": "IssueCandidate",
  "type": "object",
  "required": ["id", "title", "summary", "relatedMetricIds", "affectedGroupIds", "riskIfIgnored", "studentCouncilFit", "estimatedBudgetRange"],
  "properties": {
    "id": { "type": "string" },
    "title": { "type": "string" },
    "summary": { "type": "string" },
    "relatedMetricIds": { "type": "array", "items": { "type": "string" } },
    "affectedGroupIds": { "type": "array", "items": { "type": "string" } },
    "minorityConcerns": { "type": "array", "items": { "type": "string" } },
    "riskIfIgnored": { "type": "string" },
    "studentCouncilFit": { "type": "number", "minimum": 0, "maximum": 1 },
    "estimatedBudgetRange": {
      "type": "array",
      "prefixItems": [{ "type": "number" }, { "type": "number" }],
      "minItems": 2,
      "maxItems": 2
    }
  },
  "additionalProperties": false
}
